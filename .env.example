# Discord bot token used by runner.py
DISCORD_TOKEN=your_discord_token_here

# Optional comma-separated Discord user IDs. Leave empty to allow everyone.
AUTHORIZED_USERS=

# Public Minecraft address from Playit's Tunnels tab.
PLAYIT_TUNNEL_ADDRESS=

# Playit Docker agent secret key, copied from Playit's Docker setup flow.
PLAYIT_SECRET_KEY=

# Discord bot command prefix.
COMMAND_PREFIX=!R:

# Host used by the bot to talk to the Minecraft RCON endpoint.
RCON_HOST=127.0.0.1

# Minecraft server type for itzg/minecraft-server.
TYPE=NEOFORGE

# Minecraft game version.
VERSION=1.21.1

# Set to FALSE to allow offline/cracked clients. Set to TRUE for premium-only auth.
ONLINE_MODE=FALSE

# Loader version when TYPE=NEOFORGE.
NEOFORGE_VERSION=21.1.72

# World folder name inside /data. Change this to test a new modpack safely
# without touching your main world, for example: LEVEL=modpack-test-1
# LEVEL=

# Required by Mojang. Must be TRUE to start the server.
EULA=TRUE

# Java memory allocation used by the server container.
MEMORY=6G

# Default game difficulty.
DIFFICULTY=normal

# Server list message shown in the Minecraft client.
MOTD=server

# Maximum number of players allowed at once.
MAX_PLAYERS=10

# Must stay true so the bot can control the server through RCON.
ENABLE_RCON=true

# Password used for RCON authentication.
RCON_PASSWORD=change_this

# RCON TCP port exposed by the Minecraft container.
RCON_PORT=25575

# How many times the bot retries an RCON connection before giving up.
RCON_RETRIES=3

# Delay in seconds between RCON retry attempts.
RCON_RETRY_DELAY=2



# =====================================================================
# MODPACK IMPORT
# Choose ONE recipe below and uncomment only that block.
# Leave all other recipes commented.
# =====================================================================

# ---------------------------------------------------------------------
# RECIPE A - Public CurseForge modpack
# Use this when the modpack is already published on CurseForge.
# Requires a free API key: https://console.curseforge.com/
# CF_SLUG is the name shown in the modpack URL on CurseForge.
# ---------------------------------------------------------------------
# MODPACK_PLATFORM=AUTO_CURSEFORGE
# CF_API_KEY=
# CF_SLUG=

# Optional advanced CurseForge settings:
# CF_EXCLUDE_MODS=
# CF_FORCE_INCLUDE_MODS=
# CF_MOD_LOADER_VERSION=

# ---------------------------------------------------------------------
# RECIPE B - Public Modrinth modpack
# Use this when the modpack is already published on Modrinth.
# No API key is required.
# MODRINTH_MODPACK accepts a slug, project ID, or full URL.
# ---------------------------------------------------------------------
# MODPACK_PLATFORM=MODRINTH
# MODRINTH_MODPACK=

# Optional advanced Modrinth settings:
# MODRINTH_MODPACK_VERSION_TYPE=
# MODRINTH_FORCE_INCLUDE_FILES=

# ---------------------------------------------------------------------
# RECIPE C - Private or exported modpack
# Use this for a custom exported CurseForge .zip or Modrinth .mrpack.
#
# Steps:
# 1. Put the exported file inside server/modpacks/
# 2. Use the container path below, always starting with /modpacks/
# 3. For CurseForge .zip files, CF_SLUG can be any value such as custom,
#    but CF_API_KEY is still required.
# 4. For Modrinth .mrpack files, no API key is required.
# ---------------------------------------------------------------------
# -- CurseForge .zip path --
# MODPACK_PLATFORM=AUTO_CURSEFORGE
# CF_API_KEY=
# CF_SLUG=custom
# CF_MODPACK_ZIP=/modpacks/name-of-your-pack.zip

# -- OR Modrinth .mrpack path --
# MODPACK_PLATFORM=MODRINTH
# MODRINTH_MODPACK=/modpacks/name-of-your-pack.mrpack

# ---------------------------------------------------------------------
# OPTION D - Loose mods, no formal modpack
# Do not set any MODPACK_PLATFORM value.
# Just choose the right loader above (TYPE=FABRIC / FORGE / NEOFORGE),
# copy .jar files into server/data/mods, and restart the server.
# ---------------------------------------------------------------------

# IMPORTANT - existing world compatibility
# Changing modpacks, loaders, or Minecraft versions on an existing saved
# world can break that world. Removed mods may leave missing blocks,
# entities, or partial corruption behind.
#
# To test a new modpack safely, set LEVEL to a separate world folder:
# LEVEL=modpack-test-1
#
# Each different LEVEL value creates or uses a different world folder
# under /data, so you can validate the pack before using it on your main
# world.
